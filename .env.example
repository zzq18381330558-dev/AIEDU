# PostgreSQL 连接地址。生产环境请替换为生产数据库账号、密码、主机和库名。
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_edu_admin?schema=public"

# Session Cookie 签名密钥。
# 生产环境必须设置强随机值，禁止使用默认开发密钥 local-dev-session-secret-change-me。
# 可用命令生成：openssl rand -base64 48
SESSION_SECRET="replace-with-a-long-random-secret"
